@page
@model RazorEFApp.Pages.StudentsModel

<h2>Student List</h2>

<table border="1">
    <tr >
        <th>Id</th>
        <th>Name</th>
        <th>Age</th>
    </tr>

    @foreach (var s in Model.StudentList)
    {
        <tr>
            <td>@s.Id</td>
            <td>@s.Name</td>
            <td>@s.Age</td>
        </tr>
    }
</table>
