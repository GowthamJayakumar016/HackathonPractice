@page "/code/edit/{id:int}"

@inject NavigationManager navigation;
@using Studentmanagement.Client.Services;;
@inject IJSRuntime JsRuntime
@rendermode InteractiveServer 
@using StudentManagement.Shared.Models

<div class="row">
    <div class="col-12">
        <div class="card">
            <div class="card-header">
                <h3 class="card-title">Update Code</h3>
            </div>
            <div class="card-body">
                <EditForm Model="@codeobj" OnValidSubmit="UpdateCode" FormName="updateCode">
                    <DataAnnotationsValidator />
                    <ValidationSummary />
                    <div class="col-md-12">
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label class="control-label">System Code</label>
                                    <InputText for="Code" class="form-control" @bind-Value="@codeobj.Code" />
                                    <ValidationMessage For="@(()=>codeobj.Code)" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label class="control-label">System Code Description</label>
                                    <InputText for="Description" class="form-control" @bind-Value="@codeobj.Description" />
                                    <ValidationMessage For="@(()=>codeobj.Description)" />
                                </div>
                            </div>
                        </div>
                        <div class="form-group mt-4">
                            <button type="submit" class="btn btn-primary">Update Code</button>
                            <button type="button" @onclick="()=>Cancel()" class="btn btn-danger">Back to List</button>
                        </div>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
</div>
@code {

    [SupplyParameterFromForm]
    public SystemCode codeobj { get; set; } = new();


    [Parameter]
    public int id { get; set; }


    protected override async Task OnInitializedAsync()
    {
        await LoadCountry();
    }
    public async Task LoadCountry()
    {
        codeobj = await SystemCodeService.GetByIdAsync(id);
    }


    protected async Task UpdateCode()
    {
        var result = SystemCodeService.UpdateAsync(codeobj);
        navigation.NavigateTo("/systemcodes-list");
    }
    public void Cancel()
    {
        navigation.NavigateTo("/systemcodes-list");
    }
}
