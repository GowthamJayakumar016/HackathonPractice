@page "/add-students"

@using StudentManagement.Shared.Models
@using Studentmanagement.Models
@inject NavigationManager navigation;
@using Studentmanagement.Client.Services;;
@inject IJSRuntime JsRuntime
@rendermode InteractiveServer 
@using Microsoft.AspNetCore.Components.Forms

<h3>Add New Student</h3>

<hr />
<div class="row">
	<div class="col-md-12">
		<EditForm Model="@studobj" OnValidSubmit="CreateStudent" FormName="addstudent">
            <DataAnnotationsValidator />
            <ValidationSummary />
            <div class="col-md-12">
                <div class="row">
                     <div class="col-md-6">
                         <div class="form-group">
                             <label class="control-label">First Name</label>
                              <InputText class="form-control" @bind-Value="@studobj.Firstname"/>
                              <ValidationMessage For="@(() => studobj.Firstname)" />
                         </div>
                         <div class="form-group">
                             <label class="control-label">Middle Name</label>
                              <InputText class="form-control" @bind-Value="@studobj.Middlename"/>
                              <ValidationMessage For="@(() => studobj.Middlename)" />
                         </div>
                         <div class="form-group">
                             <label class="control-label">Last Name</label>
                              <InputText class="form-control" @bind-Value="@studobj.Lastname"/>
                              <ValidationMessage For="@(() => studobj.Lastname)" />
                         </div>
                         <div class="form-group">
                             <label class="control-label">Email</label>
                              <InputText class="form-control" @bind-Value="@studobj.EmailAddress"/>
                              <ValidationMessage For="@(() => studobj.EmailAddress)" />
                         </div>
                         <div class="form-group">
                             <label class="control-label">Password</label>
                              <InputText class="form-control" @bind-Value="@studobj.Password"/>
                              <ValidationMessage For="@(() => studobj.Password)" />
                         </div>
                         <div class="form-group">
                             <label class="control-label">PhoneNumber</label>
                              <InputNumber class="form-control" @bind-Value="@studobj.PhoneNumber"/>
                              <ValidationMessage For="@(() => studobj.PhoneNumber)" />
                         </div>
                         <div class="form-group">
                             <label class="control-label">Country</label>
                              <InputSelect  class="form-control" @bind-Value="@studobj.Country">
                                <option value="">Select Gender</option>
                                @foreach(var country in Countries)
                                {
                                    <option  value="@country.Id">@country.Name</option>
                                }
                              </InputSelect>
                              <ValidationMessage For="@(() => studobj.Country)" />
                         </div>
                          <div class="form-group mt-4">
                              <button type="submit" class="btn btn-primary">Save Student</button>
                              <button type="button" @onclick="()=>Cancel()" class="btn btn-danger">Back to List</button>
                          </div>
                     </div>
                </div>
             </div>
        </EditForm>
       
	</div>
</div>

@code{
    [SupplyParameterFromForm]
    public Student studobj { get; set; } = new Student();
    List<Country> Countries = new List<Country>();


    protected override async Task OnInitializedAsync()
    {
        if (studobj == null)
        {
            studobj = new Student();   
        }
        Countries = await CountryService.GetAsync();
    }
    protected async Task CreateStudent()
    {
         var result = await StudentService.AddStudentAsync(studobj);

        navigation.NavigateTo("/students-list");
    }
    public void Cancel()
    {
        navigation.NavigateTo("/students-list");
    }
}